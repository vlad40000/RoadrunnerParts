{
  "entities": {
    "PartMetadata": {
      "title": "Part Metadata",
      "description": "Aggregated ratings for a specific part",
      "type": "object",
      "properties": {
        "partNumber": { "type": "string" },
        "avgRating": { "type": "number" },
        "reviewCount": { "type": "integer" }
      },
      "required": ["partNumber", "avgRating", "reviewCount"]
    },
    "PartReview": {
      "title": "Part Review",
      "description": "User review and rating for a part",
      "type": "object",
      "properties": {
        "partNumber": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["installed", "used"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["partNumber", "rating", "comment", "userId", "userEmail", "status", "createdAt"]
    }
  },
  "firestore": {
    "/parts/{partNumber}": {
      "schema": "PartMetadata",
      "description": "Root document for a part's aggregated data"
    },
    "/parts/{partNumber}/reviews/{reviewId}": {
      "schema": "PartReview",
      "description": "Reviews collection for a specific part"
    }
  }
}
