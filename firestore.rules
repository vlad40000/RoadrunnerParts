rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Validation Blueprints ---

    function isValidPartMetadata(data) {
      return data.keys().hasAll(['partNumber', 'avgRating', 'reviewCount']) 
          && data.keys().size() == 3
          && data.partNumber is string && data.partNumber.size() <= 32
          && data.avgRating is number && data.avgRating >= 0 && data.avgRating <= 5
          && data.reviewCount is int && data.reviewCount >= 0;
    }

    function isValidPartReview(data) {
      return data.keys().hasAll(['partNumber', 'rating', 'comment', 'userId', 'userEmail', 'status', 'createdAt'])
          && data.keys().size() == 7
          && data.partNumber is string && data.partNumber.size() <= 32
          && data.rating is number && data.rating >= 1 && data.rating <= 5
          && data.comment is string && data.comment.size() <= 1000
          && data.userId == request.auth.uid
          && data.userEmail == request.auth.token.email
          && data.status in ['installed', 'used']
          && data.createdAt == request.time;
    }

    // --- Collection Rules ---

    match /parts/{partNumber} {
      allow read: if true;
      allow create: if isVerified() && isValidPartMetadata(incoming()) && partNumber == incoming().partNumber && isValidId(partNumber);
      allow update: if isVerified() && isValidPartMetadata(incoming()) 
                     && incoming().partNumber == existing().partNumber
                     // Only allow updating totals
                     && incoming().diff(existing()).affectedKeys().hasOnly(['avgRating', 'reviewCount']);
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isVerified() && isValidPartReview(incoming()) && isValidId(reviewId);
        allow update: if isVerified() && isOwner(existing().userId) && isValidPartReview(incoming()) 
                      && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment', 'status', 'createdAt']);
        allow delete: if isVerified() && isOwner(existing().userId);
      }
    }
  }
}
