{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "task_id": { "type": "string" },
    "agent": { "type": "string", "enum": ["supervisor-router", "analyzer", "designer", "final-reviewer"] },
    "status": { "type": "string", "enum": ["pending", "in_progress", "complete", "rejected", "blocked"] },
    "inputs": { "type": "object" },
    "outputs": { "type": "object" },
    "artifacts": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "next_action": { "type": "string" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": ["task_id", "agent", "status", "updated_at"]
}
